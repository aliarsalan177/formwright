{
  "name": "@formwright/grid-dom",
  "version": "0.3.0",
  "description": "Virtual-DOM-free, virtualized renderer for Gridwright — sticky header, sorting, inline editing.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aliarsalan177/formwright.git",
    "directory": "packages/grid-dom"
  },
  "homepage": "https://github.com/aliarsalan177/formwright#readme",
  "bugs": "https://github.com/aliarsalan177/formwright/issues",
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "grid",
    "data-grid",
    "table",
    "virtualization",
    "signals",
    "schema-driven",
    "gridwright"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@formwright/grid-core": "workspace:*",
    "@formwright/grid-schema": "workspace:*",
    "@formwright/reactive": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^25.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
